    "v1ConnState": {
      "type": "string",
      "enum": [
        "CONN_UNDEF",
        "ESTABLISHED",
        "SYN_SENT",
        "SYN_RECV",
        "FIN_WAIT1",
        "FIN_WAIT2",
        "TIME_WAIT",
        "CLOSE",
        "CLOSE_WAIT",
        "LAST_ACK",
        "LISTEN",
        "CLOSING",
        "NEW_SYN_RECV"
      ],
      "default": "CONN_UNDEF",
      "description": "- CONN_UNDEF: CONN_UNDEF: undefined connection state\n - ESTABLISHED: ESTABLISHED: connection is established\n - SYN_SENT: SYN_SENT: connection is in SYN_SENT state\n - SYN_RECV: SYN_RECV: connection is in SYN_RECV state\n - FIN_WAIT1: FIN_WAIT1: connection is in FIN_WAIT1 state\n - FIN_WAIT2: FIN_WAIT2: connection is in FIN_WAIT2 state\n - TIME_WAIT: TIME_WAIT: connection is in TIME_WAIT state\n - CLOSE: CLOSE: connection is closed\n - CLOSE_WAIT: CLOSE_WAIT: connection is in CLOSE_WAIT state\n - LAST_ACK: LAST_ACK: connection is in LAST_ACK state\n - LISTEN: LISTEN: connection is in LISTEN state\n - CLOSING: CLOSING: connection is in CLOSING state\n - NEW_SYN_RECV: NEW_SYN_RECV: connection is in NEW_SYN_RECV state",
      "title": "ConnState: represents connection state"
    },
