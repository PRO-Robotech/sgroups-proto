    "commonIpAddrFamily": {
      "type": "string",
      "enum": [
        "IPV_UNDEF",
        "IPV4",
        "IPV6"
      ],
      "default": "IPV_UNDEF",
      "description": "- IPV_UNDEF: undefined ip version\n - IPV4: IPv4\n - IPV6: IPv6",
      "title": "IpAddrFamily: IP Address family"
    },
